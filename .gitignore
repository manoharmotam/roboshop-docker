# ==========================================
# Docker Runtime & Data
# ==========================================
# Ignore local database files or uploads mounted via volumes
.docker/
*data/
*volumes/
*.db
*.sqlite

# ==========================================
# Environment & Secrets
# ==========================================
# Never commit your local credentials, credentials or API keys
.env
.env.local
.env.*.local
*.env

# ==========================================
# Compose & Logs
# ==========================================
# Ignore local override modifications if desired by team workflows
docker-compose.override.yml
*.log
npm-debug.log*
yarn-debug.log*

# ==========================================
# Core OS / IDE (Standard cleanups)
# ==========================================
.DS_Store
.idea/
.vscode/
